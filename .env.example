# Smart Attendance System - Environment Configuration
# Development Settings

# Flask Settings
FLASK_ENV=development
SECRET_KEY=
DEBUG=True

# Database
DATABASE_URL=

# JWT
JWT_SECRET=

# QR Code Settings (FIXED: Increased timeout to prevent expiration)

QR_EXPIRY_SECONDS=90
QR_ROTATION_INTERVAL=30
QR_GRACE_PERIOD_SECONDS=30

# Server
HOST=0.0.0.0
PORT=5000



# Geolocation
ENABLE_GEOLOCATION=true
LOCATION_VERIFICATION_RADIUS=100

# Classroom Locations (Latitude, Longitude)
# Default: Mumbai coordinates - Replace with your actual classroom coordinates
# Get coordinates from Google Maps: Right-click location -> "What's here?"
CLASSROOM_LAT=
CLASSROOM_LNG=
CLASSROOM_RADIUS=100

# Session Security
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
